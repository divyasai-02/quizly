generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PROFESSOR
  STUDENT
  ADMIN
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  TRUE_FALSE
  SHORT_ANSWER
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

enum AIInsightType {
  QUIZ_GENERATION
  QUESTION_REGENERATION
  QUESTION_IMPROVEMENT
  REMEDIAL_GENERATION
  ATTEMPT_FEEDBACK
  TEACHER_ANALYTICS
}

enum AIInsightModerationStatus {
  PENDING
  ACCEPTED
  FLAGGED
  HIDDEN
}

enum NotificationType {
  AI_QUIZ_GENERATED
  STUDENT_PERFORMANCE_RISK
  QUIZ_COMPLETED
  REPORT_GENERATED
  NEW_QUIZ_ASSIGNED
  RESULT_AVAILABLE
  WEAK_TOPIC_PRACTICE_RECOMMENDED
  BADGE_UNLOCKED
  LEADERBOARD_RANK_UPDATED
  ADMIN_AI_GENERATION_CREATED
  ADMIN_NEW_USER_REGISTERED
  ADMIN_LOW_CONFIDENCE_AI_GENERATION
  ADMIN_PLATFORM_ACTIVITY_SUMMARY
}

model User {
  id                  String             @id @default(cuid())
  name                String
  email               String             @unique
  passwordHash        String
  role                UserRole
  avatarUrl           String?
  disabledAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  classrooms          Classroom[]        @relation("ProfessorClassrooms")
  enrollments         ClassroomStudent[]
  quizzes             Quiz[]             @relation("ProfessorQuizzes")
  attempts            QuizAttempt[]
  aiInsights          AIInsight[]
  questionBankItems   QuestionBankItem[]
  notifications       Notification[]
  preferences         UserPreference[]
  adminAuditLogs      AdminAuditLog[]    @relation("AdminAuditActor")
}

model Classroom {
  id          String             @id @default(cuid())
  name        String
  subject     String
  section     String?
  professorId String
  joinCode    String             @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  professor   User               @relation("ProfessorClassrooms", fields: [professorId], references: [id])
  students    ClassroomStudent[]
  quizzes     Quiz[]
  aiInsights  AIInsight[]
}

model ClassroomStudent {
  id          String    @id @default(cuid())
  classroomId String
  studentId   String
  joinedAt    DateTime  @default(now())
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
}

model Quiz {
  id               String        @id @default(cuid())
  title            String
  description      String
  subject          String
  topic            String
  difficulty       String
  status           QuizStatus    @default(DRAFT)
  professorId      String
  classroomId      String?
  timeLimitMinutes Int
  totalMarks       Float         @default(0)
  passingMarks     Float
  aiGenerated      Boolean       @default(false)
  aiPrompt         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?
  professor        User          @relation("ProfessorQuizzes", fields: [professorId], references: [id])
  classroom        Classroom?    @relation(fields: [classroomId], references: [id])
  questions        Question[]
  attempts         QuizAttempt[]
  aiInsights       AIInsight[]
}

model Question {
  id             String           @id @default(cuid())
  quizId         String
  type           QuestionType
  text           String
  explanation    String?
  marks          Float
  negativeMarks  Float            @default(0)
  timeLimitSeconds Int?
  required       Boolean          @default(true)
  shuffleOptions Boolean          @default(false)
  orderIndex     Int
  aiGenerated    Boolean          @default(false)
  sourceLabel    String?
  difficulty     String?
  topicTag       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  quiz           Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options        QuestionOption[]
  answers        AttemptAnswer[]
}

model QuestionOption {
  id         String                  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean                 @default(false)
  orderIndex Int
  question   Question                @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selections AttemptSelectedOption[]
}

model QuizAttempt {
  id               String          @id @default(cuid())
  quizId           String
  studentId        String
  status           AttemptStatus    @default(IN_PROGRESS)
  startedAt        DateTime         @default(now())
  submittedAt      DateTime?
  timeTakenSeconds Int?
  score            Float            @default(0)
  percentage       Float            @default(0)
  passed           Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  quiz             Quiz             @relation(fields: [quizId], references: [id])
  student          User             @relation(fields: [studentId], references: [id])
  answers          AttemptAnswer[]
  aiInsights       AIInsight[]
}

model AttemptAnswer {
  id              String                  @id @default(cuid())
  attemptId       String
  questionId      String
  textAnswer      String?
  isCorrect       Boolean?
  marksAwarded    Float                   @default(0)
  markedForReview Boolean                 @default(false)
  answeredAt      DateTime?
  attempt         QuizAttempt             @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        Question                @relation(fields: [questionId], references: [id])
  selectedOptions AttemptSelectedOption[]

  @@unique([attemptId, questionId])
}

model AttemptSelectedOption {
  id              String         @id @default(cuid())
  attemptAnswerId String
  optionId        String
  attemptAnswer   AttemptAnswer  @relation(fields: [attemptAnswerId], references: [id], onDelete: Cascade)
  option          QuestionOption @relation(fields: [optionId], references: [id])

  @@unique([attemptAnswerId, optionId])
}

model AIInsight {
  id               String                    @id @default(cuid())
  quizId           String?
  attemptId        String?
  classroomId      String?
  userId           String?
  type             AIInsightType
  inputJson        String
  outputJson       String
  moderationStatus AIInsightModerationStatus @default(PENDING)
  moderationNote   String?
  moderatedAt      DateTime?
  moderatedById    String?
  hiddenAt         DateTime?
  createdAt        DateTime                  @default(now())
  quiz             Quiz?                     @relation(fields: [quizId], references: [id], onDelete: SetNull)
  attempt          QuizAttempt?              @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  classroom        Classroom?                @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  user             User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model QuestionBankItem {
  id          String       @id @default(cuid())
  professorId String
  subject     String
  topic       String
  difficulty  String
  type        QuestionType
  text        String
  explanation String?
  marks       Float        @default(1)
  optionsJson String
  aiGenerated Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  professor   User         @relation(fields: [professorId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  role      UserRole
  context   String?
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, role, read])
  @@index([createdAt])
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  entity    String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
  actor     User     @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
}
